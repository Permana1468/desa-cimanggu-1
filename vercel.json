{
  "version": 2,
  "functions": {
    "index.py": {
      "runtime": "python3.12",
      "maxDuration": 10,
      "includeFiles": "frontend/dist/**,staticfiles/**"
    }
  },
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ]
}
