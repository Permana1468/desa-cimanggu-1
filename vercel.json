{
  "version": 2,
  "outputDirectory": "dist",
  "cleanUrls": true,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/admin/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/users/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "/images/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/((?!api|admin|users|static|images|assets).*)",
      "destination": "/index.html"
    }
  ]
}
