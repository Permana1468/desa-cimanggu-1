{
  "version": 2,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/users/(.*)",
      "destination": "api/index.py"
    },
    {
      "source": "/static/(.*)",
      "destination": "/static/$1"
    },
    {
      "source": "/((?!api|admin|users|static).*)",
      "destination": "/index.html"
    }
  ]
}
